# Supabase (recommended — primary database)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# MongoDB (optional legacy fallback)
MONGODB_URI=mongodb://127.0.0.1:27017/janapath-school

# Admin auth
JWT_SECRET=change-this-to-a-long-random-secret-key
ADMIN_EMAIL=admin@janapath.com
ADMIN_PASSWORD=admin1234
